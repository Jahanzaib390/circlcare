# ──────────────────────────────────────────────────────────────
# CirclCare AI — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────

# Expo public vars (accessible on frontend, prefix: EXPO_PUBLIC_)
# Android emulator should use http://10.0.2.2:3001 instead of localhost.
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_mobile_google_maps_api_key_here

# LLM keys are backend-only. Put OPENAI_API_KEY in backend/.env.
