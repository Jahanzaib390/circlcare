# CirclCare AI Backend Environment
#
# Copy this file to backend/.env and paste your real OpenAI key there.
# Never commit backend/.env.

LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.4-mini
GOOGLE_MAPS_SERVER_API_KEY=your_backend_google_maps_api_key_here
PORT=3001
NODE_ENV=development
